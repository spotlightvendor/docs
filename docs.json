{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SpotlightVendor Help Center",
  "description": "Help and documentation for SpotlightVendor — vendor compliance and bid management for senior living and healthcare facilities.",
  "colors": {
    "primary": "#3D6BFF",
    "light": "#5B82FF",
    "dark": "#2750CC"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navigation": {
    "directory": "card",
    "groups": [
      {
        "group": "For Facilities",
        "icon": "building-2",
        "expanded": true,
        "root": "facilities/index",
        "pages": [
          "facilities/getting-started",
          "facilities/invite-existing-vendors",
          "facilities/post-an-rfp",
          "facilities/review-and-award-bids",
          "facilities/manage-organization"
        ]
      },
      {
        "group": "For Vendors",
        "icon": "wrench",
        "expanded": true,
        "root": "vendors/index",
        "pages": [
          "vendors/getting-started",
          "vendors/build-your-profile",
          "vendors/respond-to-rfps",
          "vendors/free-vs-pro"
        ]
      },
      {
        "group": "Compliance & Documents",
        "icon": "shield-check",
        "expanded": true,
        "root": "compliance/index",
        "pages": [
          "compliance/what-we-accept",
          "compliance/upload-documents",
          "compliance/expiration-alerts",
          "compliance/admin-review"
        ]
      },
      {
        "group": "Billing & Plans",
        "icon": "credit-card",
        "expanded": true,
        "root": "billing/index",
        "pages": [
          "billing/vendor-plans",
          "billing/facility-contracts",
          "billing/payment-method",
          "billing/invoices"
        ]
      },
      {
        "group": "Account & Support",
        "icon": "life-buoy",
        "expanded": true,
        "root": "account/index",
        "pages": [
          "account/reset-password",
          "account/update-profile",
          "account/contact-support"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact support",
        "href": "/account/contact-support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open SpotlightVendor",
      "href": "https://app.spotlightvendor.com"
    }
  },
  "footer": {
    "socials": {
      "website": "https://spotlightvendor.com"
    }
  }
}
